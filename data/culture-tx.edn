#:culture{:id "kaz.dish.beshbarmak", :name "Beshbarmak", :country "KAZ", :kind :dish, :summary "Meat, noodles and onion broth dish of Central Asian cuisine, usually made from finely chopped boiled meat mixed with egg noodles and an onion sauce; shared across Central Asia including Kazakhstan.", :url "https://en.wikipedia.org/wiki/Beshbarmak", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "kaz.dish.baursak", :name "Baursak", :country "KAZ", :kind :dish, :summary "Fried dough food found in the cuisines of Central Asia, Idel-Ural, Mongolia and the Middle East; part of Kazakh cuisine, where 856 kg of baursaks were cooked in one day in Almaty in 2014.", :url "https://en.wikipedia.org/wiki/Boortsog", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:url "https://en.wikipedia.org/wiki/Kuurdak", :id "kaz.dish.kuurdak", :kind :dish, :name-local "қуырдақ", :country "KAZ", :retrieved-at "2026-07-17", :summary "Traditional Central Asian dish of fried meat and offal seasoned with onions and garlic, served since the era of the nomads; part of Kazakh cuisine.", :name "Kuurdak", :url-provenance :wikipedia-en}
#:culture{:id "kaz.beverage.kumis", :name "Kumis", :country "KAZ", :kind :beverage, :summary "Fermented dairy drink made from mare's milk, important to the Turkic and Mongolic peoples of the Central and East Asian steppes, including the Kazakhs.", :url "https://en.wikipedia.org/wiki/Kumis", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "kaz.beverage.shubat", :name "Shubat", :country "KAZ", :kind :beverage, :summary "Fermented camel-milk beverage of Central Asia (chal); known in Kazakhstan as shubat, where it is a staple summer food.", :url "https://en.wikipedia.org/wiki/Chal", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "kaz.craft.yurt", :name "Yurt", :country "KAZ", :kind :craft, :summary "Portable round tent of Central Asian nomads; in Kazakh tradition the shangyrak crown is passed from father to son, and a stylized version of the crown is at the center of the coat of arms of Kazakhstan.", :url "https://en.wikipedia.org/wiki/Yurt", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "kaz.festival.nauryz", :name "Nauryz (Nowruz)", :country "KAZ", :kind :festival, :summary "Spring-equinox New Year festival; a four-day public holiday in Kazakhstan, where the new year is started by cooking nauryz kozhe, and inscribed for Kazakhstan among other countries as UNESCO intangible cultural heritage.", :url "https://en.wikipedia.org/wiki/Nowruz", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "kaz.heritage.mausoleum-of-khoja-ahmed-yasawi", :name "Mausoleum of Khoja Ahmed Yasawi", :country "KAZ", :kind :heritage, :summary "Timurid mausoleum in Turkestan, southern Kazakhstan, commissioned by Timur in 1389 and designated a UNESCO World Heritage Site in 2003.", :url "https://en.wikipedia.org/wiki/Mausoleum_of_Khoja_Ahmed_Yasawi", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
